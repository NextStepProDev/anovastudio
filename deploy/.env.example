# Kopiuj do .env na serwerze produkcyjnym (w katalogu deployu) i uzupełnij.
# Sekrety generuj poleceniem: openssl rand -base64 32

# --- Baza danych ---
POSTGRES_DB=fizjo
POSTGRES_USER=fizjo
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# --- Sekrety Strapi (każdy inny, wygenerowany losowo) ---
# APP_KEYS to cztery klucze rozdzielone przecinkami
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# --- Adresy publiczne (po zakupie domeny) ---
# Musi się zgadzać z server_name w nginx.conf
STRAPI_PUBLIC_URL=https://api.DOMENA.pl

# --- Obrazy (GHCR) ---
GHCR_OWNER=nextstepprodev
# Nadpisywane przez deploy.yml wartością z pliku VERSION w repo
VERSION=latest
